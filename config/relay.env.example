# Ccode 中转站密钥 — 复制到 ~/.llm-router/.env 并填入真实值（勿提交仓库）

# OpenAI 协议 Chat Completions（Codex 侧已知）
RELAY_OPENAI_BASE_URL=https://all-api.ccode.dev/v1

# Anthropic Messages API（Claude 密钥对应网关，无 /v1 后缀）
RELAY_ANTHROPIC_BASE_URL=https://all-api.ccode.dev

# DeepSeek（若走 OpenAI 兼容路径可与 OPENAI 同 base，密钥不同）
RELAY_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
